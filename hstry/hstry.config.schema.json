{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/byteowlz/hstry/schemas/config.schema.json",
  "title": "hstry configuration",
  "description": "Configuration schema for hstry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor support"
    },
    "database": {
      "type": "string",
      "description": "Path to the hstry database file."
    },
    "adapter_paths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Directories to search for adapters."
    },
    "adapter_repos": {
      "type": "array",
      "items": { "$ref": "#/definitions/AdapterRepo" },
      "description": "Adapter repositories for updates."
    },
    "js_runtime": {
      "type": "string",
      "enum": ["auto", "bun", "deno", "node"],
      "description": "Preferred JavaScript runtime."
    },
    "embedding_endpoint": {
      "type": ["string", "null"],
      "description": "Optional embedding endpoint."
    },
    "workspaces": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Workspace roots to scan recursively."
    },
    "adapters": {
      "type": "array",
      "items": { "$ref": "#/definitions/AdapterConfig" }
    },
    "service": {
      "$ref": "#/definitions/ServiceConfig"
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/definitions/SourceConfig" }
    },
    "remotes": {
      "type": "array",
      "items": { "$ref": "#/definitions/RemoteConfig" }
    },
    "sync": {
      "$ref": "#/definitions/SyncConfig"
    },
    "search": {
      "$ref": "#/definitions/SearchConfig"
    },
    "web": {
      "$ref": "#/definitions/WebConfig"
    },
    "resume": {
      "$ref": "#/definitions/ResumeConfig"
    }
  },
  "required": [],
  "definitions": {
    "AdapterConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "enabled": { "type": "boolean", "default": true }
      },
      "required": ["name"]
    },
    "AdapterRepo": {
      "type": "object",
      "description": "An adapter repository source. Fields depend on the 'type' value.",
      "properties": {
        "name": { "type": "string", "description": "Unique name for this repo (e.g., 'official', 'community')." },
        "enabled": { "type": "boolean", "default": true, "description": "Whether this repo is enabled." },
        "type": { "type": "string", "enum": ["git", "archive", "local"], "description": "Source type: git, archive (tarball/zip), or local path." },
        "url": { "type": "string", "description": "Repository URL (for git/archive types)." },
        "git_ref": { "type": "string", "description": "Branch, tag, or commit to use (git type only)." },
        "path": { "type": "string", "description": "Path within the repo/archive where adapters are located, or local filesystem path." }
      },
      "required": ["name", "type"]
    },
    "ServiceConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "poll_interval_secs": { "type": "integer", "minimum": 1, "default": 30 },
        "search_api": { "type": "boolean", "default": true },
        "search_port": { "type": ["integer", "null"], "minimum": 1, "maximum": 65535 },
        "transport": { "type": "string", "enum": ["tcp", "unix"], "default": "tcp" }
      },
      "required": []
    },
    "SourceConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "adapter": { "type": "string" },
        "path": { "type": "string" },
        "auto_sync": { "type": "boolean", "default": true }
      },
      "required": ["id", "adapter", "path"]
    },
    "RemoteConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "host": { "type": "string" },
        "database_path": { "type": ["string", "null"] },
        "port": { "type": ["integer", "null"] },
        "identity_file": { "type": ["string", "null"] },
        "enabled": { "type": "boolean", "default": true }
      },
      "required": ["name", "host"]
    },
    "SyncConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["standalone", "hub", "satellite"], "default": "standalone" },
        "device_id": { "type": ["string", "null"] },
        "hub_remote": { "type": ["string", "null"] },
        "auto_sync": { "type": "boolean", "default": false },
        "auto_sync_interval_secs": { "type": "integer", "minimum": 1, "default": 300 }
      }
    },
    "SearchConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "index_path": { "type": ["string", "null"] },
        "index_batch_size": { "type": "integer", "minimum": 1, "default": 500 }
      }
    },
    "WebConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "headless": { "type": "boolean", "default": true },
        "sync_interval_secs": { "type": "integer", "minimum": 1, "default": 900 },
        "full_refresh_interval_secs": { "type": "integer", "minimum": 1, "default": 86400 },
        "storage_dir": { "type": ["string", "null"] },
        "providers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "chatgpt": { "$ref": "#/definitions/WebProviderConfig" },
            "claude": { "$ref": "#/definitions/WebProviderConfig" },
            "gemini": { "$ref": "#/definitions/WebProviderConfig" }
          }
        }
      }
    },
    "WebProviderConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false }
      }
    },
    "ResumeConfig": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuration for resuming sessions in coding agents.",
      "properties": {
        "default_agent": {
          "type": "string",
          "description": "Default agent to resume sessions in (e.g., 'pi', 'claude-code', 'codex').",
          "default": "pi"
        },
        "agents": {
          "type": "object",
          "description": "Per-agent resume configuration.",
          "additionalProperties": {
            "$ref": "#/definitions/AgentResumeConfig"
          }
        }
      }
    },
    "AgentResumeConfig": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuration for resuming sessions in a specific coding agent.",
      "properties": {
        "format": {
          "type": "string",
          "description": "hstry export format name (must match an adapter name)."
        },
        "command": {
          "type": "string",
          "description": "Command template to launch the agent. Placeholders: {session_path}, {session_id}, {workspace}."
        },
        "session_dir": {
          "type": "string",
          "description": "Directory where the agent stores sessions natively. Converted sessions are placed here."
        }
      },
      "required": ["format", "command", "session_dir"]
    }
  }
}
